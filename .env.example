# Copy this file to .env and fill in your values.
# Leave TURSO_URL empty to use local pkm.db (offline dev)

# --- LLM backend ---
# Which provider the pipeline calls: "gemini" (free tier, default) or "openai".
PKM_LLM_PROVIDER=gemini

# --- Gemini (Google AI Studio, free tier) — default provider ---
# Create a key at https://aistudio.google.com/apikey (free, no card required).
GEMINI_API_KEY=AIza...
# Leave as the "auto" sentinel to list Flash models and fall back by version
# (3.5 → 3.1 → 3 → 2.5 …, full flash before flash-lite). Or pin one, e.g.
# PKM_GEMINI_MODEL=gemini-2.5-flash
PKM_GEMINI_MODEL=gemini-flash-auto

# --- OpenAI (pluggable fallback; used when PKM_LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
# Base URL for the OpenAI-compatible endpoint. Default is real OpenAI.
# For local dev routing Anthropic models through CLIProxyAPI:
#   OPENAI_BASE_URL=http://127.0.0.1:8317/v1
# (verify CLIProxyAPI exposes /v1/chat/completions) and set PKM_LLM_MODEL to a claude-* id.
OPENAI_BASE_URL=https://api.openai.com/v1
# Model id (cloud default is gpt-5.4-mini). Override for local CLIProxyAPI dev.
PKM_LLM_MODEL=gpt-5.4-mini-2026-03-17

# Per-run cost guardrail (T1-02): batch_ingest aborts if either cap is exceeded.
PKM_RUN_COST_CAP_USD=0.50
PKM_RUN_TOKEN_CAP=200000

TURSO_URL=libsql://your-db.turso.io
TURSO_TOKEN=eyJ...
CF_ACCOUNT_ID=
CF_API_TOKEN=