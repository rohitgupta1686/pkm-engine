# Copy this file to .env and fill in your values.

# --- OpenAI (the locked provider for single-call note synthesis) ---
OPENAI_API_KEY=sk-...
# Base URL for the OpenAI-compatible endpoint. Default is real OpenAI; override
# only for local dev against an OpenAI-compatible proxy (e.g. CLIProxyAPI).
OPENAI_BASE_URL=https://api.openai.com/v1

# Synthesis model (full model, locked). Pricing lives in pkm/llm/pricing.py.
PKM_SYNTHESIS_MODEL=gpt-5.4
# Vault subdir the single-call path reads existing notes from / writes new notes to.
PKM_NOTES_DIRNAME=notes

# Path to your pkm-vault checkout (notes are written under <vault>/<notes dir>).
VAULT_PATH=/path/to/pkm-vault

# Per-run cost guardrail: batch-ingest aborts before exceeding this (~$0.03/note).
PKM_RUN_COST_CAP_USD=0.50
PKM_RUN_TOKEN_CAP=200000
