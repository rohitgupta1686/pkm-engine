# Copy this file to .env and fill in your values.

# --- OpenAI-compatible endpoint (Z.AI GLM-5.2 by default) ---
# Put your Z.AI API key here. The env var name stays OPENAI_API_KEY because the
# OpenAI-compatible SDK path still reads it.
OPENAI_API_KEY=...
OPENAI_BASE_URL=https://api.z.ai/api/paas/v4/

# Synthesis model. Pricing lives in pkm/llm/pricing.py.
SYNTHESIS_MODEL=glm-5.2
# Vault subdir the single-call path reads existing notes from / writes new notes to.
NOTES_DIRNAME=notes

# Path to your pkm-vault checkout (notes are written under <vault>/<notes dir>).
VAULT_PATH=/path/to/pkm-vault

# Source-notes capture folder for `pkm ingest-notes` (books/podcasts/lectures):
# one .md per source, typically an Obsidian vault synced via iCloud. Create the
# vault on a device with "Store in iCloud" ON, then point this at the synced path:
#   ~/Library/Mobile Documents/iCloud~md~obsidian/Documents/Sources
SOURCES_DIR=/path/to/icloud/Sources

# Optional local-only OCR for image embeds in source notes. Do not add this key
# to GitHub Actions secrets: `pkm ingest-notes --ocr` is a Mac-run command.
GEMINI_API_KEY=...
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OCR_MODEL=gemini-3-flash-preview
OCR_ENABLED=false

# Per-run cost guardrail: batch-ingest aborts before exceeding this.
RUN_COST_CAP_USD=0.50
RUN_TOKEN_CAP=200000
